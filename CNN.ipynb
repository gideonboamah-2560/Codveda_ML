   "source": [
    "img_path = r'C:\\Users\\LAPTOP\\Desktop\\Tensorflow\\trail.jfif'\n",
    "img = tf.keras.utils.load_img (img_path, target_size = (227,227))\n",
    "imgarr = tf.keras.utils.img_to_array(img)\n",
    "imgarr = tf.expand_dims(img, axis= 0)\n",
    "\n",
    "prediction = model.predict(imgarr)\n",
    "pred = np.argmax( prediction[0])\n",
    "pred_label = train_ds.class_names[pred]\n",
    "print(pred_label)"
   ]
